/* Context
The online hotel reservation channels have dramatically changed booking possibilities and customers’ behavior. A significant number of hotel reservations are called-off due to cancellations or no-shows. The typical reasons for cancellations include change of plans, scheduling conflicts, etc. This is often made easier by the option to do so free of charge or preferably at a low cost which is beneficial to hotel guests but it is a less desirable and possibly revenue-diminishing factor for hotels to deal with.
*/

/* Hotel Reservations dataset
https://www.kaggle.com/datasets/ahsan81/hotel-reservations-classification-dataset
*/

use hotel_reservations;
SELECT * from reservations;

/* Q1
What is the cancellation rate by market segment?
*/
SELECT 
	market_segment_type,
	ROUND(100 * SUM(CASE WHEN booking_status = 'Canceled' THEN 1 ELSE 0 END)/ COUNT(*),2) AS cancelation_rate_percentage
from reservations
GROUP BY market_segment_type
ORDER BY cancelation_rate_percentage DESC;
/* Q2
What is the cancellation rate by room type?
*/
SELECT 
	room_type_reserved,
	ROUND(100 * SUM(CASE WHEN booking_status = 'Canceled' THEN 1 ELSE 0 END)/ COUNT(*),2) AS cancelation_rate_percentage
from reservations
GROUP BY room_type_reserved
ORDER BY cancelation_rate_percentage DESC;
/* Q3
What is the cancellation rate by lead time?
*/
SELECT 
  lead_time_category,
  ROUND(100.0 * SUM(CASE WHEN booking_status = 'Canceled' THEN 1 ELSE 0 END) / COUNT(*), 2) AS cancellation_rate_percent
FROM (
  SELECT *,
    CASE 
      WHEN lead_time < 7 THEN '0-6 days'
      WHEN lead_time BETWEEN 7 AND 30 THEN '7-30 days'
      WHEN lead_time BETWEEN 31 AND 90 THEN '31-90 days'
      ELSE '90+ days'
    END AS lead_time_category
  FROM reservations
) AS categorized
GROUP BY lead_time_category
ORDER BY cancellation_rate_percent DESC;

/* Q4
What is the cancellation rate of repeated and non-repeated guests?
*/
SELECT 
  CASE
	WHEN repeated_guest = 1 THEN 'Repeated guest'
	ELSE 'Non-repeated guest'
	END AS guest,
	ROUND(100* SUM(CASE WHEN booking_status = 'Canceled' THEN 1 ELSE 0 END) / COUNT(*),2) AS cancellation_rate_percent
FROM reservations
GROUP BY repeated_guest;

/* Q4
What is the percentage of repeated guests per lead time?
*/
SELECT 
  lead_time_category,
  ROUND(100*SUM(CAST(repeated_guest AS INT)) / COUNT(*),2) AS repeated_guests_percent
FROM (
  SELECT *,
    CASE 
      WHEN lead_time < 7 THEN '0-6 days'
      WHEN lead_time BETWEEN 7 AND 30 THEN '7-30 days'
      WHEN lead_time BETWEEN 31 AND 90 THEN '31-90 days'
      ELSE '90+ days'
    END AS lead_time_category
  FROM reservations
) AS categorized
GROUP BY lead_time_category
ORDER BY repeated_guests_percent DESC;

/* Q5
How does the number of children affect length of stay?
*/
ALTER TABLE reservations ADD stay_duration INT;
UPDATE reservations set stay_duration = no_of_week_nights + no_of_weekend_nights; 

SELECT travelers_type,
		avg(stay_duration) as average_stay_duration
FROM ( SELECT *,
		CASE 
			WHEN no_of_children = 0 THEN 'Without children'
			ELSE 'With children'
			END AS travelers_type
		FROM reservations ) AS categorized
GROUP BY travelers_type;

/* Q6
How does the number children affect booking status?
*/
SELECT travelers_type,
		ROUND(100 * SUM(CASE WHEN booking_status = 'Canceled' THEN 1 ELSE 0 END)/ COUNT(*),2) AS cancelation_rate_percentage
FROM ( SELECT *,
		CASE 
			WHEN no_of_children = 0 THEN 'Without children'
			ELSE 'With children'
			END AS travelers_type
		FROM reservations ) AS categorized
GROUP BY travelers_type;
/* Q7
Are guests with more special requests more likely to cancel their bookings?
*/
SELECT no_of_special_requests,
	ROUND(100 * SUM(CASE WHEN booking_status = 'Canceled' THEN 1 ELSE 0 END)/ COUNT(*),2) AS cancelation_rate_percentage
FROM reservations
GROUP BY no_of_special_requests
ORDER BY no_of_special_requests;

/* Q8
Which months have the highest highest cancellation rates?
*/
SELECT TOP 3 arrival_month,
	ROUND(100 * SUM(CASE WHEN booking_status = 'Canceled' THEN 1 ELSE 0 END)/ COUNT(*),2) AS cancelation_rate_percentage
FROM reservations
GROUP BY arrival_month
ORDER BY cancelation_rate_percentage DESC;

/* Q9
Is there a trend in bookings with respect to the lead time across different months?
*/
SELECT arrival_month, [0-6 days], [7-30 days], [31-90 days], [90+ days]
FROM (
  SELECT arrival_month,
    CASE 
      WHEN lead_time < 7 THEN '0-6 days'
      WHEN lead_time BETWEEN 7 AND 30 THEN '7-30 days'
      WHEN lead_time BETWEEN 31 AND 90 THEN '31-90 days'
      ELSE '90+ days'
    END AS lead_time_category
  FROM reservations
) AS source_table
PIVOT (
 COUNT(lead_time_category)
  FOR lead_time_category IN ([0-6 days], [7-30 days], [31-90 days], [90+ days])
) AS pivot_table
ORDER BY arrival_month;

/* Q10
How does the average price per room vary by month?
*/
SELECT arrival_month, 
	ROUND(AVG(avg_price_per_room), 2) AS average_room_price
FROM reservations
GROUP BY arrival_month
ORDER BY arrival_month;

/* Q11
Which room types generate the highest average revenue per booking?
*/
SELECT room_type_reserved,
	ROUND(MAX(avg_price_per_room),2) AS highest_average_price
FROM reservations
GROUP BY room_type_reserved
ORDER BY highest_average_price DESC;

/* Q12
What is the average revenue loss due to cancellations by month?
*/
SELECT arrival_month,
	ROUND(SUM(avg_price_per_room),2) AS average_revenue_loss
FROM reservations
WHERE booking_status = 'Canceled'
GROUP BY arrival_month
ORDER BY average_revenue_loss DESC;

/* Q13
What is the average revenue loss due to cancellations by market segment?
*/

WITH total_rev_cte AS
	(SELECT 
		market_segment_type,
		COALESCE(ROUND(SUM(avg_price_per_room),2),0) AS total_revenue
	FROM reservations 
	GROUP BY market_segment_type
	),

lost_rev_cte AS
	(SELECT 
		market_segment_type,
		COALESCE(ROUND(SUM(avg_price_per_room),2),0) AS total_lost_revenue
	FROM reservations
	WHERE booking_status = 'Canceled'
	GROUP BY market_segment_type
	)

SELECT 
	tr.market_segment_type,
	tr.total_revenue,
	lr.total_lost_revenue,
	COALESCE(ROUND(100 * lr.total_lost_revenue / tr.total_revenue , 2),0) AS lost_revenue_percentage
FROM total_rev_cte AS tr
LEFT JOIN lost_rev_cte AS lr
ON tr.market_segment_type = lr.market_segment_type
ORDER BY lost_revenue_percentage DESC;

/* Q14
What proportion of guests require car parking, and does this vary by market segment?
*/
SELECT Count(*) AS total_bookings,
	(SELECT COUNT(*) 
		FROM reservations
		WHERE required_car_parking_space > 0) AS bookings_with_parking,
		ROUND(100* (SELECT COUNT(*) 
		FROM reservations
		WHERE required_car_parking_space > 0) / Count(*), 2) AS bookings_with_parking_percentage
FROM reservations;

/* Q15
What proportion of guests require car parking by market segment?
*/
WITH bookings_w_parking_cte AS (
										SELECT market_segment_type,
										COUNT(*) AS bookings_with_parking_count
										FROM reservations
										WHERE required_car_parking_space > 0
										GROUP BY market_segment_type
										),
	total_bookings_count_cte AS (
										SELECT market_segment_type,
										COUNT(*) AS total_bookings_count
										FROM reservations
										GROUP BY market_segment_type
										)
SELECT bwp.market_segment_type,
		tbc.total_bookings_count,
		bwp.bookings_with_parking_count,
		ROUND(100* bwp.bookings_with_parking_count / tbc.total_bookings_count, 2) bookings_with_parking_percentage
FROM bookings_w_parking_cte AS bwp
LEFT JOIN total_bookings_count_cte AS TBC
ON bwp.market_segment_type = tbc.market_segment_type
ORDER BY bookings_with_parking_percentage DESC;



